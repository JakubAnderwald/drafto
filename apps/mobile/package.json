{
  "name": "@drafto/mobile",
  "version": "1.1.2",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:arm64": "ORG_GRADLE_PROJECT_reactNativeArchitectures=arm64-v8a expo run:android",
    "android:x86_64": "ORG_GRADLE_PROJECT_reactNativeArchitectures=x86_64 expo run:android",
    "android:release-local": "set -a && source .env.production && set +a && export _JAVA_OPTIONS='--enable-native-access=ALL-UNNAMED' && cd android && ./gradlew assembleRelease && echo '\nAPK: android/app/build/outputs/apk/release/app-release.apk'",
    "ios": "expo run:ios",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:beta": "eas build --profile beta",
    "build:prod": "eas build --profile production",
    "submit:ios": "eas submit --platform ios",
    "submit:android": "eas submit --platform android",
    "beta:ios": "eas build --profile beta --platform ios --auto-submit",
    "beta:android": "eas build --profile beta --platform android --auto-submit",
    "beta:all": "eas build --profile beta --platform all --auto-submit",
    "eas-build-pre-install": "echo 'node-linker=hoisted' > ../../.npmrc"
  },
  "dependencies": {
    "@10play/tentap-editor": "^1.0.1",
    "@drafto/shared": "workspace:*",
    "@expo/vector-icons": "^15.1.1",
    "@nozbe/watermelondb": "^0.28.0",
    "@nozbe/with-observables": "^1.6.0",
    "@react-native-community/netinfo": "^11.5.2",
    "@supabase/supabase-js": "^2.100.0",
    "expo": "~55.0.8",
    "expo-constants": "~55.0.9",
    "expo-crypto": "^55.0.10",
    "expo-document-picker": "^55.0.9",
    "expo-file-system": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-image-picker": "^55.0.13",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
    "expo-secure-store": "^55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "^55.0.10",
    "react": "19.2.4",
    "react-native": "0.84.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-webview": "^13.16.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.11",
    "react-test-renderer": "19.2.4",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@nozbe/watermelondb",
          "@nozbe/with-observables"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
