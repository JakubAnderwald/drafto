# Ensure UTF-8 locale for CocoaPods (required when launched from launchd/cron)
ENV["LANG"] ||= "en_US.UTF-8"
ENV["LC_ALL"] ||= "en_US.UTF-8"

default_platform(:mac)

BUNDLE_ID = "eu.drafto.mobile"
PROJECT_ROOT = File.expand_path("..", __dir__)

# ---------- helpers ----------

def load_local_secrets
  secrets_file = File.join(Dir.home, "drafto-secrets", "android-env.sh")
  return unless File.exist?(secrets_file)

  File.readlines(secrets_file).each do |line|
    line = line.strip
    next if line.empty? || line.start_with?("#")
    next unless line.start_with?("export ")

    assignment = line.sub(/^export\s+/, "")
    key, value = assignment.split("=", 2)
    next unless key && value
    next if value.include?("$(")

    value = value.gsub(/\A["']|["']\z/, "")
    value = value.gsub("$HOME", Dir.home)
    ENV[key] ||= value
  end
end

load_local_secrets

def post_release_notes(max_chars:)
  Dir.chdir(PROJECT_ROOT) do
    notes = sh("bash", "scripts/generate-release-notes.sh", "--max-chars", max_chars.to_s).strip
    sh("node", "scripts/post-release-notes.mjs", "--platform", "macos", "--notes", notes) unless notes.empty?
  end
rescue StandardError => e
  UI.important("Release notes posting failed (non-fatal): #{e.message}")
end

# Phase G: walk PRs merged since the last `desktop@*` tag, find `Closes #N`
# refs, and comment "Now live in <track>." on each linked support issue.
# `track` is the customer-facing label (e.g. "TestFlight macOS build 145").
# Best-effort — a comment failure shouldn't fail the release pipeline.
def comment_released_issues(build:, track:)
  return if build.nil? || build.to_s.empty? || track.nil? || track.empty?
  Dir.chdir(PROJECT_ROOT) do
    repo_root = `git rev-parse --show-toplevel`.strip
    script = File.join(repo_root, "scripts", "comment-released-issues.mjs")
    next unless File.exist?(script)
    sh("node", script,
       "--platform", "macos",
       "--build", build.to_s,
       "--track", track,
       "--tag-prefix", "desktop@",
       "--paths", "apps/desktop/,packages/shared/")
  end
rescue StandardError => e
  UI.important("Released-issue comments failed (non-fatal): #{e.message}")
end

def package_json_version
  require "json"
  JSON.parse(File.read(File.join(PROJECT_ROOT, "package.json")))["version"]
end

# ---------- macOS ----------

platform :mac do
  desc "Build and submit to TestFlight (macOS)"
  lane :beta do
    build_and_submit(destination: "testflight")
  end

  desc "Build and submit to App Store (macOS)"
  lane :production do
    build_and_submit(destination: "appstore")
  end

  private_lane :build_and_submit do |options|
    destination = options[:destination]

    # Known Supabase project refs (public — they appear in URLs and shipped bundles; not secrets).
    known_prod_ref = "tbmjbxxseonkciqovnpl"
    known_dev_ref = "huhzactreblzcogqkbsd"

    # Bundle PROD Supabase credentials into this release.
    #
    # react-native-dotenv gives `process.env` the HIGHEST precedence over the `.env` file
    # (see undefObjectAssign in the plugin), so we inject `.env.production` into the
    # environment here — the same approach mobile uses (load_production_env) — rather than
    # copying it onto `.env`. The copy approach was silently overridden by the environment,
    # which is why 0.3.2 build 28 shipped DEV credentials. Injecting via the environment
    # also leaves `.env` (dev) untouched, so local debug builds keep using dev.
    #
    # Fail-fast: require `.env.production` and verify it points at the prod project (URL +
    # anon key). The bundle guard after build_mac_app then double-checks the compiled
    # output. Credential values are never logged.
    prod_env = File.join(PROJECT_ROOT, ".env.production")
    UI.user_error!("Missing apps/desktop/.env.production — cannot bundle prod credentials") unless File.exist?(prod_env)

    prod_env_contents = File.read(prod_env)
    prod_env_ref = prod_env_contents[%r{^SUPABASE_URL=https://([a-z0-9]+)\.supabase\.co}, 1]
    unless prod_env_ref == known_prod_ref
      UI.user_error!(".env.production must point at the prod Supabase project (#{known_prod_ref}); found #{prod_env_ref.inspect} — refusing to build")
    end
    if prod_env_contents[/^SUPABASE_ANON_KEY=(.+)$/, 1].to_s.strip.empty?
      UI.user_error!(".env.production is missing SUPABASE_ANON_KEY — refusing to build")
    end

    # Inject every key from .env.production into the environment so react-native-dotenv
    # inlines the prod values during bundling (process.env overrides the .env file).
    prod_env_contents.each_line do |line|
      line = line.strip
      next if line.empty? || line.start_with?("#")
      key, value = line.split("=", 2)
      ENV[key] = value if key && value
    end

    # Install CocoaPods dependencies
    cocoapods(
      podfile: File.join(PROJECT_ROOT, "macos", "Podfile"),
      try_repo_update_on_error: true
    )

    # Fix NSClassFromString nil crash in RCTThirdPartyComponentsProvider on macOS.
    # The auto-generated file uses an NSDictionary literal with NSClassFromString() values.
    # Some classes (e.g. RNSFullWindowOverlay) are iOS-only and return nil on macOS,
    # which crashes NSDictionary's initWithObjects:forKeys:count:.
    # Replace the @{} literal with NSMutableDictionary that skips nil values.
    provider_mm = File.join(PROJECT_ROOT, "macos", "build", "generated", "ios", "RCTThirdPartyComponentsProvider.mm")
    if File.exist?(provider_mm)
      content = File.read(provider_mm)
      if content.include?("thirdPartyComponents = @{")
        pairs = content.scan(/@"(\w+)":\s*NSClassFromString\(@"(\w+)"\)/)
        if pairs.any?
          safe_lines = pairs.map { |key, cls|
            "    { Class c = NSClassFromString(@\"#{cls}\"); if (c) dict[@\"#{key}\"] = c; }"
          }
          safe_body = "NSMutableDictionary *dict = [NSMutableDictionary new];\n#{safe_lines.join("\n")}\n    thirdPartyComponents = [dict copy];"
          patched = content.sub(/thirdPartyComponents = @\{[^}]+\};/m, safe_body)
          File.write(provider_mm, patched) if patched != content
          UI.success("Patched RCTThirdPartyComponentsProvider.mm for nil-safe macOS class lookup")
        end
      end
    end

    # Configure App Store Connect API key
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_API_ISSUER_ID"],
      key_filepath: ENV["ASC_API_KEY_P8_PATH"],
      key_content: ENV["ASC_API_KEY_P8"],
      in_house: false
    )

    # Remove stale "Apple Distribution" certs to avoid ambiguity during archive.
    # Match may have previously installed a mac_installer_distribution cert with the same
    # "Apple Distribution" name, causing Xcode to fail with "profile doesn't include cert".
    keychain = File.expand_path("~/Library/Keychains/login.keychain-db")
    hashes = `security find-certificate -a -c "Apple Distribution" -Z "#{keychain}" 2>/dev/null`
      .scan(/SHA-1 hash: (\w+)/).flatten
    hashes.each { |h| system("security", "delete-certificate", "-Z", h, keychain) }

    # Fetch macOS app distribution cert + profile from match
    match(
      type: "appstore",
      platform: "macos",
      app_identifier: BUNDLE_ID,
      api_key: api_key,
      readonly: true
    )

    # Sync version from package.json to Xcode MARKETING_VERSION
    version = package_json_version
    increment_version_number(
      version_number: version,
      xcodeproj: File.join(PROJECT_ROOT, "macos", "Drafto.xcodeproj")
    )

    # Auto-increment build number from TestFlight
    latest_build = begin
      latest_testflight_build_number(
        api_key: api_key,
        app_identifier: BUNDLE_ID,
        platform: "osx"
      )
    rescue StandardError => e
      UI.important("Could not fetch latest build number (#{e.message}), defaulting to 0")
      0
    end

    new_build_number = latest_build + 1
    increment_build_number(
      build_number: new_build_number,
      xcodeproj: File.join(PROJECT_ROOT, "macos", "Drafto.xcodeproj")
    )

    # Update code signing for the macOS target
    update_code_signing_settings(
      path: File.join(PROJECT_ROOT, "macos", "Drafto.xcodeproj"),
      use_automatic_signing: false,
      team_id: "4J2USPSG2U",
      profile_name: "match AppStore eu.drafto.mobile macos",
      code_sign_identity: "Apple Distribution",
      targets: ["Drafto-macOS"]
    )

    # Strip NSAllowsArbitraryLoads for App Store submission
    update_info_plist(
      xcodeproj: File.join(PROJECT_ROOT, "macos", "Drafto.xcodeproj"),
      plist_path: "Drafto-macOS/Info.plist",
      block: proc do |plist|
        ats = plist["NSAppTransportSecurity"]
        if ats
          ats.delete("NSAllowsArbitraryLoads")
          ats.delete("NSExceptionDomains")
          plist.delete("NSAppTransportSecurity") if ats.empty?
        end
      end
    )

    # Build and export .app (skip .pkg — we create it separately with the installer cert).
    build_mac_app(
      workspace: File.join(PROJECT_ROOT, "macos", "Drafto.xcworkspace"),
      scheme: "Drafto-macOS",
      export_method: "app-store",
      output_directory: File.join(PROJECT_ROOT, "macos", "build"),
      skip_package_pkg: true,
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          BUNDLE_ID => "match AppStore eu.drafto.mobile macos"
        }
      }
    )

    # Keystone guard: verify the COMPILED bundle points at the prod Supabase project and
    # contains no dev reference, before anything is uploaded. Makes it structurally
    # impossible to ship a dev-pointed build again (the cause of 0.3.2 build 28). Matches
    # only the public project ref/URL — never the anon key.
    js_bundle = File.join(PROJECT_ROOT, "macos", "build", "Drafto.app", "Contents", "Resources", "main.jsbundle")
    UI.user_error!("Built bundle not found at #{js_bundle}") unless File.exist?(js_bundle)
    bundle_strings = `strings -a "#{js_bundle}"`
    unless bundle_strings.include?(known_prod_ref)
      UI.user_error!("Release bundle does not reference the prod Supabase project (#{known_prod_ref}) — aborting upload")
    end
    if bundle_strings.include?(known_dev_ref)
      UI.user_error!("Release bundle references the DEV Supabase project (#{known_dev_ref}) — aborting upload")
    end
    UI.success("Verified release bundle points at prod Supabase project #{known_prod_ref}")

    # Create .pkg with the "3rd Party Mac Developer Installer" cert (created via Xcode)
    app_path = File.join(PROJECT_ROOT, "macos", "build", "Drafto.app")
    pkg_path = File.join(PROJECT_ROOT, "macos", "build", "Drafto.pkg")
    sh("productbuild",
       "--component", app_path, "/Applications",
       "--sign", "3rd Party Mac Developer Installer: Jakub Anderwald (4J2USPSG2U)",
       pkg_path)

    # Upload
    if destination == "testflight"
      upload_to_testflight(
        api_key: api_key,
        pkg: pkg_path,
        skip_waiting_for_build_processing: false
      )
    else
      upload_to_app_store(
        api_key: api_key,
        pkg: pkg_path,
        skip_metadata: true,
        skip_screenshots: true,
        precheck_include_in_app_purchases: false
      )
    end

    # Post release notes
    post_release_notes(max_chars: 4000)

    # Phase G: comment "Now live" on closed support issues for this build.
    # TestFlight (beta) and the App Store (production) ship the same macOS
    # build to different audiences — distinguish in the customer label.
    track_label =
      destination == "appstore" ? "the macOS App Store (build #{new_build_number})" : "TestFlight macOS (build #{new_build_number})"
    comment_released_issues(build: new_build_number, track: track_label)

    # Tag this release (e.g. desktop@0.3.2+45) so generate-release-notes.sh scopes
    # the NEXT build's "What to Test" to the delta since this build, instead of
    # dumping the whole history. There were no desktop@ tags at all because
    # desktop ships manually from the primary-checkout fossil (see
    # docs/operations/desktop-build-fossil.md), so the desktop-*-release.yml CI
    # tag job never runs — tag here instead. `-v:refname` orders the +build suffix
    # numerically (verified). Non-fatal: a tag/push failure must not fail an
    # already-shipped release.
    begin
      release_tag = "desktop@#{version}+#{new_build_number}"
      if `git tag -l "#{release_tag}"`.strip.empty?
        sh("git", "tag", release_tag)
        sh("git", "push", "origin", release_tag)
        UI.success("Tagged release #{release_tag}")
      else
        UI.message("Release tag #{release_tag} already exists — skipping")
      end
    rescue StandardError => e
      UI.important("Release tagging failed (non-fatal): #{e.message}")
    end
  end
end
