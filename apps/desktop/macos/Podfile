require 'pathname'

ws_dir = Pathname.new(__dir__)
ws_dir = ws_dir.parent until
  File.exist?("#{ws_dir}/node_modules/react-native-macos/scripts/react_native_pods.rb") ||
  ws_dir.expand_path.to_s == '/'
require "#{ws_dir}/node_modules/react-native-macos/scripts/react_native_pods.rb"

prepare_react_native_project!

target 'Drafto-macOS' do
  platform :macos, '14.0'
  use_native_modules!

  use_react_native!(
    :path => '../../../node_modules/react-native-macos',
    :fabric_enabled => ENV['RCT_NEW_ARCH_ENABLED'] == '1',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # WatermelonDB and simdjson are auto-linked by use_native_modules!
  # Both patched via pnpm patch to add macOS platform support

  post_install do |installer|
    react_native_post_install(installer)

    # Build arm64 only — macOS 14+ targets Apple Silicon; Rosetta handles Intel Macs
    installer.pods_project.build_configurations.each do |config|
      config.build_settings['EXCLUDED_ARCHS[sdk=macosx*]'] = 'x86_64'
    end

    # Fix fmt consteval errors on Xcode 26+ — consteval is broken in Apple Clang
    # Patch fmt/base.h to skip consteval detection on Apple builds (see issue #242)
    fmt_base = File.join(installer.sandbox.root, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      File.chmod(0644, fmt_base)
      content = File.read(fmt_base)
      patched = content
        .gsub('#elif defined(__cpp_consteval)', '#elif defined(__cpp_consteval) && !defined(__apple_build_version__)')
        .gsub('#elif FMT_GCC_VERSION >= 1002 || FMT_CLANG_VERSION >= 1101', '#elif (FMT_GCC_VERSION >= 1002 || FMT_CLANG_VERSION >= 1101) && !defined(__apple_build_version__)')
      File.write(fmt_base, patched) if patched != content
    end

    # Fix NSClassFromString nil crash in RCTThirdPartyComponentsProvider on macOS.
    # The codegen generates an NSDictionary literal with NSClassFromString() values.
    # Some classes (e.g. RNSFullWindowOverlay) are iOS-only and return nil on macOS,
    # which crashes NSDictionary's initWithObjects:forKeys:count: (nil not allowed).
    # Patch: 1) template uses NSMutableDictionary, 2) generator emits nil-safe setObject calls.
    # Must patch ALL copies: react-native, react-native-macos, and react-native-macos/node_modules/react-native
    nm_dir = File.join(ws_dir.to_s, 'node_modules')
    Dir.glob(File.join(nm_dir, '**', 'codegen', 'templates', 'RCTThirdPartyComponentsProviderMM.template')).each do |template_mm|
      content = File.read(template_mm)
      if content.include?('thirdPartyComponents = @{')
        patched = content
          .sub("thirdPartyComponents = @{\n{thirdPartyComponentsMapping}\n    };",
               "NSMutableDictionary *dict = [NSMutableDictionary new];\n{thirdPartyComponentsMapping}\n        thirdPartyComponents = [dict copy];")
        File.write(template_mm, patched) if patched != content
      end
    end

    Dir.glob(File.join(nm_dir, '**', 'codegen', 'generate-artifacts-executor', 'generateRCTThirdPartyComponents.js')).each do |generator_js|
      content = File.read(generator_js)
      old_line = 'return `\\t\\t@"${componentName}": NSClassFromString(@"${className}"), // ${library}`;'
      new_line = 'return `\\t\\t{ Class c = NSClassFromString(@"${className}"); if (c) dict[@"${componentName}"] = c; } // ${library}`;'
      if content.include?(old_line)
        File.write(generator_js, content.sub(old_line, new_line))
      end
    end

    # Fix dispatch_queue_t strong property error on Xcode 26+ / macOS SDK
    # CocoaPods adds -DOS_OBJECT_USE_OBJC=0 as per-file compiler flags, which makes
    # dispatch_queue_t a non-ObjC type and breaks 'strong' properties in RCTBridgeModule.h
    installer.pods_project.targets.each do |target|
      next unless target.respond_to?(:source_build_phase)
      target.source_build_phase.files.each do |file|
        next unless file.settings && file.settings['COMPILER_FLAGS']
        file.settings['COMPILER_FLAGS'] = file.settings['COMPILER_FLAGS']
          .gsub('-DOS_OBJECT_USE_OBJC=0', '-DOS_OBJECT_USE_OBJC=1')
      end
    end
  end
end
